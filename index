<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>JS Task Manager</title>
        <style>
            *, *::before, *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }
            body {
                font-family: 'Segoe UI', system-ui, sans-serif;
                background-color: black;
                color: whitesmoke;
                display: flex;
                justify-content: center;
                padding-top: 5rem;
            }
            main {
                background-color: darkslategray;
                width: 100%;
                max-width: 500px;
                padding: 2rem;
                border-radius: 12px;
                box-shadow: 0 10px 30px black;
            }
            form {
                display: flex;
                gap: 0.5rem;
                margin-bottom: 1.5rem;
            }
            input {
                flex-grow: 1;
                border: 1px solid gray;
                font-size: 1rem;
            }
            button[type="submit"] {
                cursor: pointer;
                font-weight: bold;
            }
            button[type="submit"]:hover {
                background-color: blue;
            }
            #filters-container {
                justify-content: center;
                border-bottom: 1px solid gray;
            }
            #filters-container button {
                background: none;
                border: none;
            }
            ul {
                list-style: none;
            }
            li {
                display: flex;
                justify-content: space-between;
                align-items: center;
            }
        </style>
    </head>
    <body>
        <main>
            <h1>Task Manager</h1>
        <form id="todo-form">
            <input type="text" id="todo-input" placeholder="What needs to be done?" required>
            <button type="submit">Add Task</button>
        </form>
        <div id="filters-container">
            <button data-filter="all">All</button>
            <button data-filter="active">Active</button>
            <button data-filter="completed">Completed</button>
        </div>
        <ul id="todo-list"></ul>
        </main>
        <script>
            // === 1. STATE (The Brain's Memory) ===
let tasks = JSON.parse(localStorage.getItem('tasks')) || [];
let currentFilter = 'all';

// === 2. DOM HOOKS (The Hands) ===
const form = document.getElementById('todo-form');
const input = document.getElementById('todo-input');
const list = document.getElementById('todo-list');
const filters = document.getElementById('filters-container');

// === 3. CORE LOGIC (CRUD Operations) ===
function addTask(text) {
    const newTask = { 
        id: Date.now().toString(), 
        text: text, 
        completed: false 
    };
    tasks.push(newTask);
    saveAndRender();
}

function toggleTask(id) {
    tasks = tasks.map(task => {
        if (task.id === id) {
            return { ...task, completed: !task.completed };
        }
        return task;
    });
    saveAndRender();
}

function deleteTask(id) {
    tasks = tasks.filter(task => task.id !== id);
    saveAndRender();
}

// === 4. THE RENDER ENGINE (The Screen) ===
function saveAndRender() {
    // Save to hard drive
    localStorage.setItem('tasks', JSON.stringify(tasks));
    
    // Wipe the screen blank
    list.innerHTML = '';

    // Apply filters
    let filteredTasks = tasks;
    if (currentFilter === 'active') {
        filteredTasks = tasks.filter(task => !task.completed);
    } else if (currentFilter === 'completed') {
        filteredTasks = tasks.filter(task => task.completed);
    }

    // Draw the array onto the screen
    filteredTasks.forEach(task => {
        const li = document.createElement('li');
        // Add a strikethrough if completed so we can see it working
        if (task.completed) li.style.textDecoration = 'line-through';
        
        li.innerHTML = `
            <span onclick="toggleTask('${task.id}')" style="cursor:pointer;">
                ${task.completed ? '✅' : '⬜'} ${task.text}
            </span>
            <button onclick="deleteTask('${task.id}')">Delete</button>
        `;
        list.appendChild(li);
    });
}

// === 5. EVENT LISTENERS (The Triggers) ===
form.addEventListener('submit', function(e) {
    e.preventDefault(); 
    const text = input.value.trim();
    if (text !== '') {
        addTask(text);
        input.value = ''; 
    }
});

filters.addEventListener('click', function(e) {
    if (e.target.tagName === 'BUTTON') {
        currentFilter = e.target.getAttribute('data-filter');
        saveAndRender();
    }
});

// === 6. INITIAL BOOT ===
saveAndRender();
        </script>
    </body>
</html>